{
    "version": 2,
    "builds": [
      {
        "src": "main.py",
        "use": "@vercel/python"
      }
    ],
    "routes": [
      {
        "src": "/(.*)",
        "dest": "main.py"
      }
    ],
    "env": {
      "SUPABASE_URL": "@SUPABASE_URL",
      "SUPABASE_SERVICE_KEY": "@SUPABASE_SEVICE_KEY",
      "GEMINI_API_KEY": "@GEMINI_API_KEY",
      "DEEPSEEK_API_KEY": "@DEEPSEEK_API_KEY",
      "GROQ_API_KEY": "@GROQ_API_KEY",
      "KIMI_API_KEY": "@KIMI_API_KEY"
    }
  }
