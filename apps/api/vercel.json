{
    "version": 2,
    "builds": [
      {
        "src": "main.py",
        "use": "@vercel/python"
      }
    ],
    "routes": [
      {
        "src": "/(.*)",
        "dest": "main.py"
      }
    ],
    "env": {
      "SUPABASE_URL": "@supabase_url",
      "SUPABASE_SERVICE_KEY": "@supabase_service_key",
      "GEMINI_API_KEY": "@gemini_api_key",
      "DEEPSEEK_API_KEY": "@deepseek_api_key",
      "GROQ_API_KEY": "@groq_api_key",
      "KIMI_API_KEY": "@kimi_api_key"
    }
  }